---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: "About", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Resources", href: "/resources" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="mt-24 bg-ink-50 border-t border-ink-100">

  <!-- Newsletter signup bar -->
  <div class="max-w-6xl mx-auto px-6 py-12 border-b border-ink-100">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-forest-700 mb-3 font-semibold">Newsletter</p>
        <h3 class="text-2xl mb-2">Dairy insights, straight to your inbox.</h3>
        <p class="text-ink-700 max-w-md">Monthly notes on nutrition, herd health, and what's working on real farms. No spam, unsubscribe anytime.</p>
      </div>
      <form class="flex flex-col sm:flex-row gap-3" onsubmit="event.preventDefault(); alert('Newsletter signup coming soon — we\\'ll wire this up in a later phase.');">
        <input
          type="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 rounded-md bg-white border border-ink-300 text-ink-900 placeholder:text-ink-500 focus:outline-none focus:border-forest-700 focus:ring-2 focus:ring-forest-200 transition-all"
          aria-label="Your email address"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-md bg-forest-700 text-white font-medium shadow-sm hover:bg-forest-800 hover:shadow-md transition-all"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>

  <!-- Main footer columns -->
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Column 1 — Brand + bio -->
      <div>
        <a href="/" class="flex items-center gap-0.5 text-xl font-bold tracking-tight text-ink-900 mb-4">
          <span>Brave Dairy Hub</span>
          <span class="text-amber-brand-400">.</span>
        </a>
        <p class="text-sm text-ink-700 max-w-xs">
          Dairy consulting, training, and practical resources — drawing on hands-on experience from Ugandan smallholders to leading Israeli farms.
        </p>
      </div>

      <!-- Column 2 — Site nav -->
      <div>
        <h4 class="text-xs uppercase tracking-widest text-ink-500 font-semibold mb-4">Explore</h4>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-ink-700 hover:text-forest-700 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3 — Contact + social -->
      <div>
        <h4 class="text-xs uppercase tracking-widest text-ink-500 font-semibold mb-4">Get in touch</h4>
        <ul class="space-y-2 mb-5">
          <li>
            <a href="mailto:braveatwemeriireho@gmail.com" class="text-sm text-ink-700 hover:text-forest-700 transition-colors">
              braveatwemeriireho@gmail.com
            </a>
          </li>
          <li class="text-sm text-ink-700">Kampala, Uganda</li>
        </ul>

        <!-- Social icons row -->
        <div class="flex items-center gap-3">
          <a href="https://linkedin.com/in/" aria-label="LinkedIn" class="inline-flex items-center justify-center h-10 w-10 rounded-md border border-ink-300 text-ink-700 hover:border-forest-700 hover:text-forest-700 transition-colors">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11 19h-3v-10h3v10zm-1.5-11.27c-.97 0-1.75-.79-1.75-1.76s.78-1.76 1.75-1.76 1.75.79 1.75 1.76-.78 1.76-1.75 1.76zm12.5 11.27h-3v-5.3c0-3.18-3.75-2.94-3.75 0v5.3h-3v-10h3v1.76c1.4-2.58 7-2.78 7 2.47v5.77z"/>
            </svg>
          </a>
          <a href="#" aria-label="X (Twitter)" class="inline-flex items-center justify-center h-10 w-10 rounded-md border border-ink-300 text-ink-700 hover:border-forest-700 hover:text-forest-700 transition-colors">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube" class="inline-flex items-center justify-center h-10 w-10 rounded-md border border-ink-300 text-ink-700 hover:border-forest-700 hover:text-forest-700 transition-colors">
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Copyright strip -->
  <div class="border-t border-ink-100">
    <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-ink-500">
        © {currentYear} Atwemeriireho Brave. All rights reserved.
      </p>
      <p class="text-xs text-ink-500">
        Built with Astro &middot; Hosted on Netlify
      </p>
    </div>
  </div>

</footer>