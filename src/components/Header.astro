---
const navItems = [
  { label: "About", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Resources", href: "/resources" },
  { label: "Blog", href: "/blog" },
];
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-ink-100">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <a href="/" class="group flex items-center gap-0.5 text-xl font-bold tracking-tight text-ink-900 hover:text-forest-700 transition-colors">
      <span>Brave Dairy Hub</span>
      <span class="text-amber-brand-400 group-hover:scale-125 transition-transform origin-center">.</span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {navItems.map(item => (
        <a href={item.href} class="text-sm font-medium text-ink-700 hover:text-forest-700 transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/contact" class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-forest-700 text-white text-sm font-medium shadow-sm hover:bg-forest-800 hover:shadow-md transition-all">
      Book a consultation
    </a>

    <button
      id="mobile-menu-toggle"
      class="md:hidden inline-flex items-center justify-center h-10 w-10 rounded-md text-ink-900 hover:bg-ink-100 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-ink-100 bg-white">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {navItems.map(item => (
        <a href={item.href} class="py-3 px-2 rounded-md text-base font-medium text-ink-900 hover:bg-sage-50 hover:text-forest-700 transition-colors">
          {item.label}
        </a>
      ))}
      <a href="/contact" class="mt-3 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-md bg-forest-700 text-white font-medium hover:bg-forest-800 transition-colors">
        Book a consultation
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>