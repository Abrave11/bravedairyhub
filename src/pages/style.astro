---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Style Tile — Brave Dairy Hub">
  <main class="max-w-5xl mx-auto px-6 py-16">

    <!-- Page header -->
    <header class="mb-20 border-b border-ink-300 pb-10">
      <p class="text-xs uppercase tracking-[0.2em] text-forest-700 mb-4 font-semibold">Style Tile · v2</p>
      <h1 class="text-5xl md:text-6xl mb-5">Brave Dairy Hub — Visual Language</h1>
      <p class="text-lg text-ink-700 max-w-2xl">Reference page showing colors, typography, buttons, and components used across the site. Not linked from public navigation.</p>
    </header>

    <!-- ============================================
         Color Palette
         ============================================ -->
    <section class="mb-20">
      <h2 class="text-3xl mb-2">Color Palette</h2>
      <p class="text-ink-700 mb-10">White-forward. Forest green for brand and trust. Amber for accents. Ink for text.</p>

      <!-- Forest green scale -->
      <div class="mb-10">
        <h3 class="text-base mb-4 text-ink-700 font-semibold">Forest Green — Primary</h3>
        <div class="grid grid-cols-5 md:grid-cols-10 gap-2">
          <div class="text-center"><div class="h-16 rounded-md bg-forest-50 border border-ink-300"></div><p class="text-xs mt-1 text-ink-500">50</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-100"></div><p class="text-xs mt-1 text-ink-500">100</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-200"></div><p class="text-xs mt-1 text-ink-500">200</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-300"></div><p class="text-xs mt-1 text-ink-500">300</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-400"></div><p class="text-xs mt-1 text-ink-500">400</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-500"></div><p class="text-xs mt-1 text-ink-500">500</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-600"></div><p class="text-xs mt-1 text-ink-500">600</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-700 ring-2 ring-amber-brand-400 ring-offset-2 ring-offset-white"></div><p class="text-xs mt-1 font-semibold text-forest-700">700 ★</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-800"></div><p class="text-xs mt-1 text-ink-500">800</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-forest-900"></div><p class="text-xs mt-1 text-ink-500">900</p></div>
        </div>
      </div>

      <!-- Amber accent -->
      <div class="mb-10">
        <h3 class="text-base mb-4 text-ink-700 font-semibold">Amber — Accent</h3>
        <div class="grid grid-cols-5 md:grid-cols-6 gap-2">
          <div class="text-center"><div class="h-16 rounded-md bg-amber-brand-50 border border-ink-300"></div><p class="text-xs mt-1 text-ink-500">50</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-amber-brand-100"></div><p class="text-xs mt-1 text-ink-500">100</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-amber-brand-200"></div><p class="text-xs mt-1 text-ink-500">200</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-amber-brand-300"></div><p class="text-xs mt-1 text-ink-500">300</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-amber-brand-400 ring-2 ring-forest-700 ring-offset-2 ring-offset-white"></div><p class="text-xs mt-1 font-semibold text-amber-brand-500">400 ★</p></div>
          <div class="text-center"><div class="h-16 rounded-md bg-amber-brand-500"></div><p class="text-xs mt-1 text-ink-500">500</p></div>
        </div>
      </div>

      <!-- Sage + Ink -->
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-base mb-4 text-ink-700 font-semibold">Sage — Section tints</h3>
          <div class="grid grid-cols-4 gap-2">
            <div class="text-center"><div class="h-14 rounded bg-sage-50 border border-ink-300"></div><p class="text-xs mt-1 text-ink-500">50</p></div>
            <div class="text-center"><div class="h-14 rounded bg-sage-100"></div><p class="text-xs mt-1 text-ink-500">100</p></div>
            <div class="text-center"><div class="h-14 rounded bg-sage-200"></div><p class="text-xs mt-1 text-ink-500">200</p></div>
            <div class="text-center"><div class="h-14 rounded bg-sage-300"></div><p class="text-xs mt-1 text-ink-500">300</p></div>
          </div>
        </div>

        <div>
          <h3 class="text-base mb-4 text-ink-700 font-semibold">Ink — Text &amp; borders</h3>
          <div class="grid grid-cols-6 gap-2">
            <div class="text-center"><div class="h-14 rounded bg-ink-900"></div><p class="text-xs mt-1 text-ink-500">900</p></div>
            <div class="text-center"><div class="h-14 rounded bg-ink-700"></div><p class="text-xs mt-1 text-ink-500">700</p></div>
            <div class="text-center"><div class="h-14 rounded bg-ink-500"></div><p class="text-xs mt-1 text-ink-500">500</p></div>
            <div class="text-center"><div class="h-14 rounded bg-ink-300"></div><p class="text-xs mt-1 text-ink-500">300</p></div>
            <div class="text-center"><div class="h-14 rounded bg-ink-100"></div><p class="text-xs mt-1 text-ink-500">100</p></div>
            <div class="text-center"><div class="h-14 rounded bg-ink-50 border border-ink-300"></div><p class="text-xs mt-1 text-ink-500">50</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================
         Typography
         ============================================ -->
    <section class="mb-20">
      <h2 class="text-3xl mb-2">Typography</h2>
      <p class="text-ink-700 mb-10">Inter throughout — bold, crisp, corporate. Fraunces reserved for editorial moments like blockquotes.</p>

      <div class="space-y-10">

        <div class="border-l-2 border-amber-brand-400 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Style reference</p>
          <p class="text-xs uppercase tracking-[0.2em] text-forest-700 font-semibold">Eyebrow label</p>
          <p class="text-xs text-ink-500 mt-2 italic">Forest green caps. Small and tight. Sits above major headings.</p>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Heading 1 — page titles</p>
          <h1 class="text-5xl md:text-6xl mb-1">Practical dairy expertise, grounded in fieldwork.</h1>
          <p class="text-xs text-ink-500 mt-2 italic">Inter 800, tight tracking. Mobile: 3rem. Desktop: 3.75rem.</p>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Heading 2 — section titles</p>
          <h2 class="text-4xl mb-1">What I do on the farm</h2>
          <p class="text-xs text-ink-500 mt-2 italic">Inter 700.</p>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Heading 3 — subsections</p>
          <h3 class="text-2xl mb-1">Reproduction &amp; fertility</h3>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Lead paragraph</p>
          <p class="text-xl text-ink-700 leading-relaxed max-w-2xl">After years of studying and working with dairy cattle across Uganda and Israel, I help farmers improve milk yield, herd health, and farm economics through field-tested, practical methods.</p>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Body text</p>
          <p class="max-w-2xl">Israel's dairy industry produces some of the highest yields per cow in the world, largely through disciplined nutrition, climate-adapted housing, and tight reproductive management. These same principles apply to Ugandan farms, with local adaptations.</p>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Inline links</p>
          <p class="max-w-2xl">
            Inline links look like
            <a href="#" class="text-forest-700 underline decoration-amber-brand-400 decoration-2 underline-offset-4 hover:text-forest-900 transition-colors">this example link</a>
            — forest green with an amber underline.
          </p>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">Blockquote — editorial moment</p>
          <blockquote class="border-l-4 border-amber-brand-400 pl-6 py-2 max-w-2xl">
            <p class="font-editorial text-2xl italic text-ink-900 leading-relaxed">"Brave helped us rethink our milking routine from the ground up. Yields rose within three months."</p>
            <footer class="text-sm text-ink-500 mt-3 not-italic">— Farm owner, Mbarara</footer>
          </blockquote>
          <p class="text-xs text-ink-500 mt-2 italic">Fraunces serif here, used sparingly for quotes and testimonials.</p>
        </div>

      </div>
    </section>

    <!-- ============================================
         Buttons
         ============================================ -->
    <section class="mb-20">
      <h2 class="text-3xl mb-2">Buttons</h2>
      <p class="text-ink-700 mb-10">Four variants. Hover to see transitions.</p>

      <div class="space-y-8">

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-3">Primary — main CTA</p>
          <div class="flex flex-wrap gap-3">
            <a href="#" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-forest-700 text-white font-medium shadow-sm hover:bg-forest-800 hover:shadow-md transition-all">Book a consultation</a>
            <a href="#" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-forest-700 text-white font-medium shadow-sm hover:bg-forest-800 hover:shadow-md transition-all">Get in touch <span aria-hidden="true">→</span></a>
          </div>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-3">Secondary — amber accent</p>
          <div class="flex flex-wrap gap-3">
            <a href="#" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-amber-brand-400 text-ink-900 font-medium shadow-sm hover:bg-amber-brand-500 hover:text-white hover:shadow-md transition-all">Download study guide</a>
            <a href="#" class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-amber-brand-400 text-ink-900 font-medium shadow-sm hover:bg-amber-brand-500 hover:text-white hover:shadow-md transition-all">Subscribe to newsletter</a>
          </div>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-3">Outline — tertiary</p>
          <div class="flex flex-wrap gap-3">
            <a href="#" class="inline-flex items-center gap-2 px-6 py-3 rounded-md border-2 border-forest-700 text-forest-700 font-medium hover:bg-forest-700 hover:text-white transition-colors">Read more</a>
            <a href="#" class="inline-flex items-center gap-2 px-6 py-3 rounded-md border-2 border-forest-700 text-forest-700 font-medium hover:bg-forest-700 hover:text-white transition-colors">View all projects</a>
          </div>
        </div>

        <div class="border-l-2 border-ink-300 pl-6">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-3">Text link with arrow</p>
          <div class="flex flex-wrap gap-6">
            <a href="#" class="group inline-flex items-center gap-2 text-forest-700 font-medium hover:text-forest-900 transition-colors">Read the full case study <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span></a>
            <a href="#" class="group inline-flex items-center gap-2 text-forest-700 font-medium hover:text-forest-900 transition-colors">Explore resources <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span></a>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================
         Stats + Cards — on light sage section for contrast
         ============================================ -->
    <section class="mb-20">
      <h2 class="text-3xl mb-2">Stats &amp; Cards</h2>
      <p class="text-ink-700 mb-10">Floating white cards with soft shadows — lift on hover for a tactile, product-like feel.</p>

      <!-- Stat callouts on sage tint -->
      <div class="mb-12 bg-sage-50 rounded-2xl p-8 md:p-10 border border-sage-100">
        <p class="text-xs uppercase tracking-[0.2em] text-forest-700 mb-6 font-semibold">Proof points</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <p class="text-5xl font-bold text-forest-700 mb-2">12,000+</p>
            <p class="text-sm text-ink-700">litres per cow / year in leading Israeli dairies</p>
          </div>
          <div>
            <p class="text-5xl font-bold text-forest-700 mb-2">95%</p>
            <p class="text-sm text-ink-700">of Israeli farms use integrated herd monitoring</p>
          </div>
          <div>
            <p class="text-5xl font-bold text-forest-700 mb-2">6</p>
            <p class="text-sm text-ink-700">core services — from planning to reproduction</p>
          </div>
        </div>
      </div>

      <!-- Project cards -->
      <div class="mb-12">
        <p class="text-xs uppercase tracking-widest text-ink-500 mb-4">Project cards — floating on white</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <a href="#" class="group block bg-white rounded-xl overflow-hidden border border-ink-300 shadow-[0_1px_2px_rgba(15,26,20,0.04),0_4px_12px_rgba(15,26,20,0.06)] hover:shadow-[0_2px_4px_rgba(15,26,20,0.06),0_12px_28px_rgba(15,26,20,0.10)] hover:-translate-y-1 transition-all duration-200">
            <div class="aspect-video bg-sage-100 flex items-center justify-center">
              <span class="text-sage-300 text-sm">[ project image ]</span>
            </div>
            <div class="p-6">
              <p class="text-xs uppercase tracking-[0.2em] text-forest-700 mb-2 font-semibold">Farm design · 2024</p>
              <h3 class="text-xl mb-2">Dairy farm layout — Yotvata, Israel</h3>
              <p class="text-sm text-ink-700 mb-4">Site visit and layout review for a 400-cow facility adapting to arid climate conditions.</p>
              <span class="inline-flex items-center gap-2 text-forest-700 font-medium text-sm">Read case study <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span></span>
            </div>
          </a>

          <a href="#" class="group block bg-white rounded-xl overflow-hidden border border-ink-300 shadow-[0_1px_2px_rgba(15,26,20,0.04),0_4px_12px_rgba(15,26,20,0.06)] hover:shadow-[0_2px_4px_rgba(15,26,20,0.06),0_12px_28px_rgba(15,26,20,0.10)] hover:-translate-y-1 transition-all duration-200">
            <div class="aspect-video bg-sage-100 flex items-center justify-center">
              <span class="text-sage-300 text-sm">[ project image ]</span>
            </div>
            <div class="p-6">
              <p class="text-xs uppercase tracking-[0.2em] text-forest-700 mb-2 font-semibold">Nutrition · 2024</p>
              <h3 class="text-xl mb-2">Ration redesign — Mbarara smallholder co-op</h3>
              <p class="text-sm text-ink-700 mb-4">Redesigned feed rations for 24 smallholder farms, lifting average yield by 28% over six months.</p>
              <span class="inline-flex items-center gap-2 text-forest-700 font-medium text-sm">Read case study <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span></span>
            </div>
          </a>

        </div>
      </div>

      <!-- Resource cards -->
      <div class="mb-12">
        <p class="text-xs uppercase tracking-widest text-ink-500 mb-4">Resource cards — compact</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

          <a href="#" class="group flex items-start gap-4 bg-white border border-ink-300 rounded-xl p-5 shadow-[0_1px_2px_rgba(15,26,20,0.04),0_4px_12px_rgba(15,26,20,0.06)] hover:shadow-[0_2px_4px_rgba(15,26,20,0.06),0_12px_28px_rgba(15,26,20,0.10)] hover:-translate-y-0.5 transition-all duration-200">
            <div class="flex-shrink-0 h-12 w-12 rounded-lg bg-amber-brand-100 text-amber-brand-500 flex items-center justify-center font-bold text-sm">PDF</div>
            <div class="flex-1 min-w-0">
              <p class="text-xs uppercase tracking-widest text-ink-500 mb-1">Nutrition · Study guide</p>
              <h3 class="text-base mb-1">Feed ration planning for small dairies</h3>
              <p class="text-sm text-ink-500">12 pages · Free download</p>
            </div>
          </a>

          <a href="#" class="group flex items-start gap-4 bg-white border border-ink-300 rounded-xl p-5 shadow-[0_1px_2px_rgba(15,26,20,0.04),0_4px_12px_rgba(15,26,20,0.06)] hover:shadow-[0_2px_4px_rgba(15,26,20,0.06),0_12px_28px_rgba(15,26,20,0.10)] hover:-translate-y-0.5 transition-all duration-200">
            <div class="flex-shrink-0 h-12 w-12 rounded-lg bg-amber-brand-100 text-amber-brand-500 flex items-center justify-center font-bold text-sm">PDF</div>
            <div class="flex-1 min-w-0">
              <p class="text-xs uppercase tracking-widest text-ink-500 mb-1">Reproduction · Factsheet</p>
              <h3 class="text-base mb-1">Heat detection — quick reference card</h3>
              <p class="text-sm text-ink-500">2 pages · Free download</p>
            </div>
          </a>

        </div>
      </div>

      <!-- Blog post list -->
      <div>
        <p class="text-xs uppercase tracking-widest text-ink-500 mb-4">Blog post — editorial list</p>
        <a href="#" class="group block py-6 border-b border-ink-300 hover:border-forest-700 transition-colors">
          <p class="text-xs uppercase tracking-widest text-ink-500 mb-2">12 March 2026 · Nutrition · 4 min read</p>
          <h3 class="text-2xl mb-2 group-hover:text-forest-700 transition-colors">Why feed by-products outperform imported concentrates for Ugandan smallholders</h3>
          <p class="text-ink-700 mb-3 max-w-2xl">Brewers' grain, maize bran, and cottonseed cake are often dismissed as "low quality." Done right, they outperform imported concentrates on both yield and economics.</p>
          <span class="inline-flex items-center gap-2 text-forest-700 font-medium text-sm">Read article <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span></span>
        </a>
      </div>

    </section>

    <!-- Footer note -->
    <footer class="mt-20 pt-8 border-t border-ink-300 text-center">
      <p class="text-sm text-ink-500">End of Style Tile · Brave Dairy Hub visual system</p>
    </footer>

  </main>
</Layout>